<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_premium_gradient"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/reportsToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Analytics &amp; Reports"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_premium_gradient"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-80dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan Approval Rate"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/recoveryCircle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            app:indicatorColor="@color/ngo_primary"
                            app:trackColor="#E0F2F1"
                            app:indicatorSize="160dp"
                            app:trackThickness="16dp"
                            app:trackCornerRadius="8dp"
                            android:progress="0"/>

                        <TextView
                            android:id="@+id/tvApprovalRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="0%"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Funds Disbursed vs Target (Rs 3.0M)"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvFundsDisbursedText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/ngo_accent"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/fundsProgressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progress="0"
                        app:indicatorColor="@color/ngo_accent"
                        app:trackColor="#FFF3E0"
                        app:trackCornerRadius="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Application Distribution"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="*"
                        android:layout_marginBottom="24dp">

                        <TableRow android:background="#E8F5E9" android:padding="12dp">
                            <TextView android:text="Category" android:textStyle="bold" android:textColor="@color/ngo_primary"/>
                            <TextView android:text="Applications" android:textStyle="bold" android:gravity="center" android:textColor="@color/ngo_primary"/>
                        </TableRow>

                        <TableRow android:padding="12dp">
                            <TextView android:text="Education Loan" android:textColor="@color/text_dark"/>
                            <TextView android:id="@+id/tvEduCount" android:text="0" android:gravity="center" android:textStyle="bold"/>
                        </TableRow>

                        <TableRow android:padding="12dp">
                            <TextView android:text="Small Business" android:textColor="@color/text_dark"/>
                            <TextView android:id="@+id/tvBizCount" android:text="0" android:gravity="center" android:textStyle="bold"/>
                        </TableRow>

                        <TableRow android:padding="12dp">
                            <TextView android:text="Medical / Others" android:textColor="@color/text_dark"/>
                            <TextView android:id="@+id/tvMedCount" android:text="0" android:gravity="center" android:textStyle="bold"/>
                        </TableRow>
                    </TableLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Borrower Satisfaction"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="8dp"/>

                    <RatingBar
                        android:id="@+id/satisfactionRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:rating="4.8"
                        android:stepSize="0.5"
                        android:progressTint="@color/ngo_accent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/exportPdfCheckbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Include graphical charts in PDF"
                        android:textColor="@color/text_dark"
                        android:checked="true"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportReport"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="EXPORT FULL REPORT"
                        android:textStyle="bold"
                        app:icon="@android:drawable/ic_menu_save"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/ngo_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>