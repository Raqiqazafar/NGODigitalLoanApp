<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <View
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/bg_premium_gradient"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/usersToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Manage Borrowers"
        app:titleTextColor="@color/white" />

    <!-- 🌟 UPDATED SEARCH CARD WITH CHECKBOX 🌟 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="80dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white">

        <!-- Card ke andar LinearLayout lagaya taake 2 cheezein aa sakein -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeWidth="0dp"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/ngo_primary"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchUsersInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search borrower by name or email..."
                    android:textColorHint="#9E9E9E"
                    android:inputType="text"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 🌟 NAYA CHECKBOX 🌟 -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbShowArchived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Archived (Deleted) Users"
                android:textColor="#757575"
                android:textSize="13sp"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="8dp"
                app:buttonTint="@color/ngo_primary"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 🌟 INCREASED MARGIN (140dp se 185dp kiya taake overlap na ho) 🌟 -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshUsers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="185dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/usersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="16dp"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:alpha="0.2"
            app:tint="@color/ngo_primary"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No borrowers found."
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/ngo_accent"
        app:tint="#212121"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>