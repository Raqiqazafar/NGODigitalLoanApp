<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_premium_gradient"
        app:elevation="8dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/reviewToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Review Application"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Applicant Profile"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvApplicantName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="16dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:clipToPadding="false">
                        <com.google.android.material.chip.ChipGroup
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleLine="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone..."
                                app:chipIcon="@android:drawable/ic_menu_call"
                                app:chipIconTint="@color/ngo_primary"
                                android:textColor="@color/text_dark"
                                app:chipBackgroundColor="#F4F6F8"
                                app:chipStrokeColor="#E0E0E0"
                                app:chipStrokeWidth="1dp"
                                android:clickable="false"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipCnic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CNIC..."
                                app:chipIcon="@android:drawable/ic_menu_recent_history"
                                app:chipIconTint="@color/ngo_primary"
                                android:textColor="@color/text_dark"
                                app:chipBackgroundColor="#F4F6F8"
                                app:chipStrokeColor="#E0E0E0"
                                app:chipStrokeWidth="1dp"
                                android:clickable="false"/>
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loan Category"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvLoanPurpose"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date Required"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvDateReq"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Repayment Plan"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvRepaymentPlan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Declared Income"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvMonthlyIncome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not Provided"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:background="#F9FBE7"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Specific Reason / Description"
                            android:textStyle="bold"
                            android:textColor="@color/ngo_primary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvDetailedReason"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requested Amount"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvRequestedAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/ngo_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adjust Approved Amount"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="10dp"/>

                    <!-- 🌟 ADMIN AMOUNT SLIDER 🌟 -->
                    <com.google.android.material.slider.Slider
                        android:id="@+id/amountSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="2000000"
                        android:value="0"
                        android:stepSize="10000"
                        app:labelBehavior="floating"
                        app:thumbColor="@color/ngo_primary"
                        app:trackColorActive="@color/ngo_primary_dark"
                        app:trackColorInactive="#E0E0E0"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Admin Remarks (Required for rejection)"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/adminRemarksInput"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Final Decision"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/actionToggleGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        app:singleSelection="true"
                        app:checkedButton="@+id/btnApprove">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReject"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REJECT"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="#D32F2F"
                            android:textColor="#D32F2F"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApprove"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APPROVE"
                            app:backgroundTint="@color/ngo_primary"/>
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitAction"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SUBMIT DECISION"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/ngo_accent"
                android:textColor="@color/text_dark"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>